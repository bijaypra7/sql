4. Requested Queries
Find all students with GPA > 3.5
sql
SELECT student_id, first_name, last_name, gpa
FROM students
WHERE gpa > 3.5
ORDER BY gpa DESC;
Count students in each age group
sql
SELECT 
    CASE 
        WHEN age < 20 THEN 'Under 20'
        WHEN age BETWEEN 20 AND 21 THEN '20-21'
        ELSE '22 and over'
    END AS age_group,
    COUNT(*) AS student_count
FROM students
GROUP BY age_group
ORDER BY age_group;
List students enrolled in "Computer Science" courses
sql
SELECT DISTINCT s.student_id, s.first_name, s.last_name
FROM students s
JOIN enrollments e ON s.student_id = e.student_id
JOIN courses c ON e.course_id = c.course_id
WHERE c.department = 'Computer Science'
ORDER BY s.last_name, s.first_name;
Calculate average GPA by department
sql
SELECT 
    department,
    ROUND(AVG(gpa), 2) AS average_gpa,
    COUNT(*) AS student_count
FROM students
GROUP BY department
ORDER BY average_gpa DESC;
Bonus Query: List all Computer Science courses with enrolled students
sql
SELECT 
    c.course_name,
    s.first_name,
    s.last_name,
    s.gpa
FROM courses c
JOIN enrollments e ON c.course_id = e.course_id
JOIN students s ON e.student_id = s.student_id
WHERE c.department = 'Computer Science'
ORDER BY c.course_name, s.last_name;
