#Data Manipulation
1.INSERT - Adds new records
INSERT INTO students (student_id, first_name, last_name, age, grade)
VALUES (1, 'John', 'Doe', 18, 3.75);
-- Insert multiple records
INSERT INTO students VALUES
(2, 'Jane', 'Smith', 19, 3.90),
(3, 'Mike', 'Johnson', 20, 3.45);
2.SELECT - Retrieves data
 Select all columns
SELECT * FROM students;
-- Select specific columns
SELECT first_name, last_name, grade FROM students;
-- Select with condition
SELECT * FROM students WHERE grade > 3.5;
-- Select with sorting
SELECT * FROM students ORDER BY grade DESC;
-- Select with limit
SELECT * FROM students LIMIT 2;
3.UPDATE - Modifies existing records
UPDATE students 
SET grade = 4.0 
WHERE student_id = 1;

4.DELETE - Removes records
DELETE FROM students 
WHERE student_id = 3;

# Query Clauses
WHERE - Filters records
SELECT * FROM students WHERE age >= 19;
ORDER BY - Sorts results
SELECT * FROM students ORDER BY last_name ASC;
GROUP BY - Groups rows
SELECT age, COUNT(*) 
FROM students 
GROUP BY age;
HAVING - Filters groups
SELECT age, AVG(grade) 
FROM students 
GROUP BY age 
HAVING AVG(grade) > 3.5;

 
